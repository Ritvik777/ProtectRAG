# =============================================================================
# ProtectRAG — environment template
# =============================================================================
# Copy:  cp .env.example .env
# Load:  pip install python-dotenv   then at app startup:  load_dotenv()
#
# Heuristic-only scanning needs NONE of the variables below. Set them only if
# you use LLMScanner / HybridScanner, or if your app exports OpenTelemetry.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM classification — install: pip install "protectrag[llm]"
# OpenAI-compatible Chat Completions OR Anthropic Messages (Claude).
# -----------------------------------------------------------------------------
# Provider: auto | openai | openai_compatible | anthropic | claude
# "auto" picks Anthropic if OPENAI_BASE_URL contains anthropic.com, else OpenAI.
# PROTECTRAG_LLM_PROVIDER=auto

# --- OpenAI-compatible path (default) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic (Claude) path: set provider + key (OPENAI_API_KEY not required) ---
# PROTECTRAG_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Model id for the active provider (cheap/fast models are best for classification).
PROTECTRAG_LLM_MODEL=gpt-4o-mini
# Example for Claude: PROTECTRAG_LLM_MODEL=claude-3-5-haiku-20241022

# HybridScanner — strongest recall: LLM classifies EVERY chunk (clean + heuristic HIGH).
# Best for catching subtle RAG poisoning; highest cost/latency. Overrides LLM_ALWAYS / SKIP flags when set.
# PROTECTRAG_HYBRID_MAX_RECALL=true

# Run the LLM on every chunk that heuristics mark clean (skips LLM when heuristics already HIGH by default).
# PROTECTRAG_HYBRID_LLM_ALWAYS=true

# Set to "false" to also call the LLM when heuristics already say HIGH (second opinion).
# PROTECTRAG_HYBRID_SKIP_LLM_IF_HIGH=false

# Optional: Azure OpenAI often needs a non-OpenAI path + API version header.
# Set base URL to your Azure endpoint and add headers in LLMScanConfig.extra_headers
# or your HTTP client — see README.

# -----------------------------------------------------------------------------
# OpenTelemetry (your app / collector — not read by ProtectRAG directly)
# -----------------------------------------------------------------------------
# Use when you install protectrag[otel] and configure the OTel SDK in your process.
# OTEL_SERVICE_NAME=protectrag-ingest
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_TRACES_EXPORTER=otlp

# -----------------------------------------------------------------------------
# Safety
# -----------------------------------------------------------------------------
# Never commit a real .env file. Keep secrets in a password manager or your
# platform’s secret store (Kubernetes secrets, GitHub Actions secrets, etc.).
