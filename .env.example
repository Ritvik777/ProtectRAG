# =============================================================================
# ProtectRAG — environment template
# =============================================================================
# Copy:  cp .env.example .env
# Load:  pip install python-dotenv   then at app startup:  load_dotenv()
#
# Heuristic-only scanning needs NONE of the variables below. Set them only if
# you use LLMScanner / HybridScanner, or if your app exports OpenTelemetry.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM classification (OpenAI-compatible API) — install: pip install "protectrag[llm]"
# -----------------------------------------------------------------------------
# Required for LLM calls unless you set api_key= on LLMScanConfig in code.
OPENAI_API_KEY=

# Base URL for Chat Completions (OpenAI, Azure OpenAI resource, vLLM, LiteLLM proxy, etc.)
OPENAI_BASE_URL=https://api.openai.com/v1

# Small, cheap model is recommended for classification (latency + cost).
PROTECTRAG_LLM_MODEL=gpt-4o-mini

# Optional: Azure OpenAI often needs a non-OpenAI path + API version header.
# Set base URL to your Azure endpoint and add headers in LLMScanConfig.extra_headers
# or your HTTP client — see README.

# -----------------------------------------------------------------------------
# OpenTelemetry (your app / collector — not read by ProtectRAG directly)
# -----------------------------------------------------------------------------
# Use when you install protectrag[otel] and configure the OTel SDK in your process.
# OTEL_SERVICE_NAME=protectrag-ingest
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_TRACES_EXPORTER=otlp

# -----------------------------------------------------------------------------
# Safety
# -----------------------------------------------------------------------------
# Never commit a real .env file. Keep secrets in a password manager or your
# platform’s secret store (Kubernetes secrets, GitHub Actions secrets, etc.).
